# Copy to config/secrets.env and fill in your values.
# NEVER commit config/secrets.env to git.

# --- Plaid (financial) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Google (Gmail, Calendar, Drive — one OAuth token via ingestion/google_common) ---
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json
GOOGLE_TOKEN_PATH=config/google_token.json

# Optional: limit Drive ingest to a folder ID (from Drive URL)
# GDRIVE_FOLDER_ID=

# --- Apple Notes (HTML export folder) ---
# APPLE_NOTES_EXPORT_PATH=/path/to/exported/html

# --- Raindrop.io (bookmarks API) ---
# RAINDROP_TOKEN=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- App config ---
DB_PATH=storage/secondbrain.db
CHROMA_PATH=storage/chroma
EMBED_MODEL=all-MiniLM-L6-v2
MCP_PORT=8000
MCP_HOST=0.0.0.0
